---
import '../assets/css/main.scss';

interface Props {
  title?: string;
}

const { title = 'Wakamiti' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="app-shell">
      <slot />
    </div>
  </body>
</html>
